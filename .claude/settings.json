{
  "permissions": {
    "allow": [
      "Bash(npm run build)",
      "Bash(npm run dev)",
      "Bash(node screenshot.mjs)",
      "Bash(node scripts/screenshot.mjs)",
      "Bash(node scripts/db-init.mjs)",
      "Bash(node scripts/db-query.mjs *)",
      "Bash(node scripts/db-add.mjs *)"
    ]
  },
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": ["@playwright/mcp"]
    },
    "sqlite": {
      "command": "npx",
      "args": ["@mokei/mcp-sqlite", "--db", "data/hydrogel.db"]
    },
    "svgmaker": {
      "command": "npx",
      "args": ["@genwave/svgmaker-mcp"]
    }
  }
}
